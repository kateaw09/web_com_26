# ตัวแปรสำหรับระบุ Port ที่ Server จะรัน
PORT=5000

# ตัวแปรสำหรับการเชื่อมต่อไปยัง MongoDB (เนื่องจากรันใน Docker และใช้ Auth จึงต้องใส่ Username และ Password)
MONGO_URI=mongodb://admin:password@localhost:27017/mern_db?authSource=admin

# ความลับสำหรับการสร้าง JWT Token (คุณสามารถเปลี่ยนเป็นรหัสที่เดายากๆ ได้ตามต้องการ)
JWT_SECRET=my_super_secret_jwt_key
